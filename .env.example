# Lisan Environment Configuration
# Copy this to .env and fill in your API keys

# OpenAI API Key (for Whisper speech recognition)
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepL API Key (for translation)
# Get it at: https://www.deepl.com/pro-api
DEEPL_API_KEY=

# ElevenLabs API Key (for text-to-speech)
# Get it at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# DeepSeek API Key (for explanations)
# Get it at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
